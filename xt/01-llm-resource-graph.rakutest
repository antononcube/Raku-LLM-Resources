#!/usr/bin/env raku
use v6.d;
use Test;
use LLM::Resources;
use LLM::Functions;

plan *;

my $llm-evaluator = llm-evaluator('Ollama', model => 'gemma3:4b');

use LLM::Resources;

subtest {
    my $spec = q:to/END/;
    make a brand new recommender with the data @dsData;
    apply LSI functions IDF, None, Cosine;
    recommend by profile for passengerSex:male, and passengerClass:1st;
    join across with @dsData on "id";
    echo the pipeline value;
    END

    ok llm-resource-graph('code-generation-by-fallback', input => {:$spec, lang => 'Raku', :split}, :$llm-evaluator);
}, 'code-generation-by-fallback';

subtest {
    my $text = slurp($*CWD ~ '/README.md');

    ok llm-resource-graph('text-summarization', input => {'$_' => $text, with-title => 'This package README' }, :$llm-evaluator);
}, 'text-summarization';

done-testing;